# --- Password protection (optional) ---
# Set a value here to require investors to enter a password before viewing the portal.
# Leave blank / omit to make the portal public.
MOONLIGHT_ACCESS_PASSWORD=

# Secret used to sign the access cookie. Any random string.
MOONLIGHT_SESSION_SECRET=change-me-to-a-random-string

# --- Analytics (optional) ---
# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX. Leave blank to disable.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Site URL (used for Open Graph / Twitter card metadata) ---
NEXT_PUBLIC_SITE_URL=https://invest.moonlight.co
